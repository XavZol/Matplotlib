   "source": [
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "fig, axs = plt.subplots(ncols=2, nrows=1)\n",
    "axs1 = axs[0]\n",
    "axs2 = axs[1]\n",
    "\n",
    "axs1.plot([1, 2, 3, 4], [1, 4, 6, 8])\n",
    "axs2.scatter([1, 2, 3, 4], [1, 4, 6, 8])\n",
    "\n",
    "axs1.set_title(\"Gráfico de Línea\")\n",
    "axs2.set_title(\"Gráfico Scatter\")\n",
    "plt.show()"
   ]
  }
